# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=sla_user
POSTGRES_PASSWORD=sla_password
POSTGRES_DB=smart_log_analyzer
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sla_user:sla_password@postgres:5432/smart_log_analyzer

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-very-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]

# ─── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.log,.txt,.csv,.json

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Set SMTP_ENABLED=true and fill credentials to send real emails
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bhavyavaidya2005@gmail.com
SMTP_PASSWORD=nnzphamplgirbojy
EMAIL_FROM=bhavyavaidya2005@gmail.com
EMAIL_FROM_NAME=Smart Log Analyzer

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
